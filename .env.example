# Base de données
# SQLite (dev / petits déploiements) :
DATABASE_URL="file:./dev.db"
# PostgreSQL (production) — voir prisma/schema.prisma pour basculer le provider :
# DATABASE_URL="postgresql://user:password@localhost:5432/inventaire"

# Secret JWT (256 bits minimum)
# Générer une valeur aléatoire forte : openssl rand -base64 32
JWT_SECRET="REMPLACER-PAR-UNE-VALEUR-ALEATOIRE-DE-32-CARACTERES-MINIMUM"

# Environnement
NODE_ENV="development"

# Clé de chiffrement pour les Server Actions (stable entre builds).
# Sans cette clé, Next.js régénère un secret à chaque `npm run build`,
# ce qui invalide les onglets/PWA déjà ouverts (« An unexpected response »).
# Générer : openssl rand -base64 32
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY="REMPLACER-PAR-UNE-CLE-STABLE-32-CARS"
