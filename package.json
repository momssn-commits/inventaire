{
  "name": "inventaire",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 4040",
    "build": "prisma generate && next build",
    "start": "next start -p 4040",
    "lint": "next lint",
    "db:push": "prisma db push --skip-generate",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "rm -f prisma/dev.db && npm run db:push && npm run db:seed",
    "db:import": "tsx prisma/import-real.ts",
    "setup": "npm install && npm run db:push && npm run db:generate && npm run db:seed"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "jose": "^5.9.6",
    "lucide-react": "^0.460.0",
    "next": "^15.5.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
